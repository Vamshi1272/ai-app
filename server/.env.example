NODE_ENV=development
PORT=5000

# JWT Secrets (use strong random strings in production)
JWT_SECRET=your_super_secret_jwt_key_here_min_64_chars_change_this
JWT_REFRESH_SECRET=your_refresh_token_secret_here_min_64_chars_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP) - use Gmail App Password or any SMTP service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=DocRevamp <noreply@docrevamp.com>

# Admin credentials (set these securely)
ADMIN_EMAIL=admin@docrevamp.com
ADMIN_PASSWORD=Admin@SecurePass123!

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# App
CLIENT_URL=http://localhost:5173
RESUME_PROCESSING_PRICE=2999

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,doc,docx
